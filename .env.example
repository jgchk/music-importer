# All config comes from the environment (12-factor). Copy to .env for local development.

# HTTP surface (REST under /api/v1/imports, MCP at /mcp, OpenAPI at /docs).
HTTP_PORT=3000
HTTP_HOST=0.0.0.0
LOG_LEVEL=info

# The service's own event-store SQLite file (never beets' library.db).
DATABASE_FILE=data/events.db

# Required: the intake directory all submissions live under. Rejection cleanup never leaves it.
# Mount intake and the beets library under ONE parent so beets' move is a rename (design D6).
INTAKE_ROOT=/music/intake

# Required: the user's beets config.yaml — authoritative for everything library-defining.
# Mount the whole beets config dir (config + library.db + plugin token files).
BEETS_CONFIG=/config/beets/config.yaml

# The Python interpreter carrying the pinned beets (the image sets this to its baked venv).
#BRIDGE_PYTHON=/opt/beets-venv/bin/python3

# Wall-clock budget per bridge invocation (a full apply runs the plugin chain, possibly networked).
#BRIDGE_TIMEOUT_MS=600000

# A candidate at or under this beets distance auto-applies; default is beets' strong-match bar.
#AUTO_APPLY_THRESHOLD=0.04

# The signed acquisition webhook receiver (POST /api/v1/webhooks/acquisitions). Absent -> dormant
# (the route is not registered). The secret is the Standard Webhooks shared secret, identical to
# the one music-downloader signs with (whsec_<base64>); point the downloader's WEBHOOK_URLS at
# http://<this-host>:3000/api/v1/webhooks/acquisitions.
#INTAKE_WEBHOOK_SECRET=whsec_...

# Required iff the receiver is active: the SENDER's root prefix its event `location`s fall under
# (the downloader's own view of the shared intake dir). It is stripped and the remainder joined
# onto INTAKE_ROOT.
#INTAKE_SOURCE_ROOT=/downloads/import

# The outbound release-verdict publisher (Standard Webhooks sender). Comma-separated subscriber
# URLs; absent/empty -> the publisher is dormant (verdicts are recorded but never delivered).
# Point it at the downloader's verdict receiver, and set VERDICT_WEBHOOK_SECRET to the SAME
# whsec_<base64> value that receiver verifies with (the downloader's own VERDICT_WEBHOOK_SECRET).
# URLs without a secret are a fatal boot error: publishing unsigned is impossible.
#VERDICT_WEBHOOK_URLS=http://<downloader-host>:3000/api/v1/webhooks/verdicts
#VERDICT_WEBHOOK_SECRET=whsec_...
